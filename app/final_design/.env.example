# Feline Skin Disease Detection - Environment Variables
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env to git!

# ===================
# AWS Configuration
# ===================
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET_NAME=your_bucket_name_here

# ===================
# Flask Configuration
# ===================
# Set to 'true' only for local development
FLASK_DEBUG=false
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# ===================
# Storage Provider
# ===================
# Options: 's3' (production) or 'mock' (testing)
STORAGE_PROVIDER=s3

# ===================
# Environment
# ===================
ENVIRONMENT=development

# ===================
# OpenTelemetry (Future - not yet implemented)
# ===================
# TODO: Add OTLP exporter for production tracing (Grafana Cloud, etc.)
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-us-east-0.grafana.net/otlp
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64(instance_id:api_key)>

# ===================
# For Hugging Face Spaces
# ===================
# These are set automatically by HF Spaces, but can be overridden:
# HF_SPACE=true
# HF_TOKEN=your_hf_token_if_needed
